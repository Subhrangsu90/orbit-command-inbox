# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Better Auth
# Secret used by Better Auth
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET=""

# Better Auth GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Drizzle
POSTGRES_USER=""
POSTGRES_PASSWORD=""
POSTGRES_DB=""
POSTGRES_PORT=""
DATABASE_URL=""

# Corsair — generate with: openssl rand -base64 32
CORSAIR_KEK=""

# Optional Google Cloud Pub/Sub topic used by Gmail push notifications.
# Example: projects/your-project/topics/gmail-notifications
GMAIL_TOPIC_ID=""

# Development-only fallback for a single-user Pub/Sub push URL.
# Multi-tenant deployments should use ?tenantId=<better-auth-user-id> instead.
CORSAIR_WEBHOOK_TENANT_ID=""

# Google OAuth credentials are stored in Corsair's DB, not in env.
# Create your own Google OAuth client, then run:
# pnpm corsair setup --plugin=gmail client_id=... client_secret=... redirect_url=http://localhost:3000/api/corsair/auth/callback
# pnpm corsair setup --plugin=googlecalendar client_id=... client_secret=... redirect_url=http://localhost:3000/api/corsair/auth/callback

# OpenAI — for AI agent chat and semantic search
OPENAI_API_KEY=""
# Must be a model available to the same OpenAI project as OPENAI_API_KEY.
OPENAI_CHAT_MODEL="gpt-4.1"

# Gemini — for email priority categorization
GEMINI_API_KEY=""
GEMINI_CHAT_MODEL="gemini-2.5-flash"
